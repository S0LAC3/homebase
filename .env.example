# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for server-side admin operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used by cron jobs to call internal API routes)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Confluent Kafka
CONFLUENT_API_KEY=your-kafka-api-key
CONFLUENT_API_SECRET=your-kafka-api-secret
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-west-2.aws.confluent.cloud:9092
CONFLUENT_REST_URL=https://your-cluster.confluent.cloud
# CONFLUENT_CLUSTER_ID=your-cluster-id  # optional, auto-discovered if omitted

# Confluent Flink (separate API key scoped to Flink)
CONFLUENT_FLINK_API_KEY=your-flink-api-key
CONFLUENT_FLINK_API_SECRET=your-flink-api-secret
CONFLUENT_FLINK_POOL_ID=lfcp-xxxxxx
CONFLUENT_ENV_ID=env-xxxxxx
CONFLUENT_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CONFLUENT_FLINK_REGION=us-west-2
CONFLUENT_FLINK_CLOUD=aws

