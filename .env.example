# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for server-side admin operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Confluent Kafka (REST Proxy)
CONFLUENT_API_KEY=your-confluent-api-key
CONFLUENT_API_SECRET=your-confluent-api-secret
CONFLUENT_REST_URL=https://your-cluster.confluent.cloud
# CONFLUENT_CLUSTER_ID=your-cluster-id  # optional, auto-discovered if omitted
